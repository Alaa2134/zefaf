# ===========================================
# Zefaf — Environment variables
# ===========================================

# Admin password — set ONE of these before deploying!
# Option A (recommended): bcrypt hash. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 12))"
ADMIN_PASSWORD_HASH=

# Option B (dev only): plaintext fallback
ADMIN_PASSWORD=zefaf2026

# Public site URL (used for OG tags, sitemap, share links, Telegram buttons)
NEXT_PUBLIC_SITE_URL=https://zefaf.online

# -------------------------------------------
# Supabase (REQUIRED for production)
# Without these, orders are stored in /tmp on Vercel and DISAPPEAR with
# every deploy. Sign up free at https://supabase.com, create a project,
# run the SQL in supabase/schema.sql, then copy these values from
# Project Settings → API.
# -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE=eyJhbGc...

# -------------------------------------------
# Telegram bot for instant order notifications (HIGHLY RECOMMENDED)
# Setup steps:
# 1. In Telegram, message @BotFather → /newbot → follow prompts → copy bot token
# 2. Send any message to your new bot (so it can DM you)
# 3. Open https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates → copy your chat id
# -------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -------------------------------------------
# Resend — transactional emails to grooms (OPTIONAL)
# Sign up at resend.com → API Keys → 3000 emails/month free
# -------------------------------------------
RESEND_API_KEY=
RESEND_FROM=Zefaf <noreply@zefaf.online>
